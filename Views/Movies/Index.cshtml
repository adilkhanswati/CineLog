@model MoviesIndexViewModel
@{
    ViewData["Title"] = "My Movies";
}

<h1>My Movies</h1>

<p class="muted">
    @Model.TotalCount total &middot; @Model.WatchedCount watched &middot; @Model.WantCount to watch
</p>

<form method="get" asp-action="Index" class="filters">
    <input type="text" name="search" value="@Model.Search" placeholder="Search title or genre" />
    <select name="status">
        <option value="">All statuses</option>
        <option value="WantToWatch" selected="@(Model.Status == "WantToWatch" ? "selected" : null)">Want to Watch</option>
        <option value="Watched" selected="@(Model.Status == "Watched" ? "selected" : null)">Watched</option>
    </select>
    <select name="sort">
        <option value="added" selected="@(Model.Sort == "added" ? "selected" : null)">Recently added</option>
        <option value="title" selected="@(Model.Sort == "title" ? "selected" : null)">Title</option>
        <option value="year" selected="@(Model.Sort == "year" ? "selected" : null)">Year</option>
        <option value="rating" selected="@(Model.Sort == "rating" ? "selected" : null)">Rating</option>
    </select>
    <select name="dir">
        <option value="desc" selected="@(Model.Dir == "desc" ? "selected" : null)">Desc</option>
        <option value="asc" selected="@(Model.Dir == "asc" ? "selected" : null)">Asc</option>
    </select>
    <button type="submit" class="btn">Apply</button>
    <a class="btn" asp-action="Index">Reset</a>
</form>

<div class="toolbar">
    <a class="btn primary" asp-action="Create">+ Add movie</a>
</div>

@if (!Model.Movies.Any())
{
    <p class="empty">No movies match your filters. Try resetting them or add a new one.</p>
}
else
{
    <table>
        <thead>
            <tr>
                <th></th>
                <th>Title</th>
                <th>Genre</th>
                <th>Year</th>
                <th>Status</th>
                <th>Rating</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in Model.Movies)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(m.PosterFileName))
                        {
                            <img src="~/uploads/@m.PosterFileName" alt="" class="poster-thumb" />
                        }
                    </td>
                    <td>@m.Title</td>
                    <td>@(string.IsNullOrWhiteSpace(m.Genre) ? "-" : m.Genre)</td>
                    <td>@m.Year</td>
                    <td>@(m.Status == WatchStatus.WantToWatch ? "Want to Watch" : "Watched")</td>
                    <td>@(m.Rating.HasValue ? $"{m.Rating}/5" : "-")</td>
                    <td class="row-actions">
                        <form asp-action="ToggleWatched" asp-route-id="@m.Id" method="post" class="inline">
                            <button type="submit" class="linkbtn">@(m.Status == WatchStatus.Watched ? "Mark unwatched" : "Mark watched")</button>
                        </form>
                        <a asp-action="Edit" asp-route-id="@m.Id">Edit</a>
                        <a asp-action="Delete" asp-route-id="@m.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
